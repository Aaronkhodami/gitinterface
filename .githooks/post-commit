#!/bin/sh
# Post-commit hook: update version.js with real SHA and replace HEAD commit.

LOCK=".git/version-lock"
if [ -f "$LOCK" ]; then rm -f "$LOCK"; exit 0; fi

SHA=$(git log -1 --format="%H")
DATE=$(git log -1 --format="%ad" --date=short)

cat > dashboard/version.js <<EOF
// -- Interface version ------------------------------------------------------
// This file is managed automatically by git post-commit hook.
window.INTERFACE_VERSION_DATE = "$DATE";
window.INTERFACE_VERSION_SHA  = "$SHA";
EOF

git add dashboard/version.js

TREE=$(git write-tree)
PARENT=$(git rev-parse HEAD)
MSG=$(git log -1 --format="%s%n%b")
NEW_COMMIT=$(echo "$MSG" | git commit-tree "$TREE" -p "$PARENT")

touch "$LOCK"
git update-ref -m "hook: update version.js" HEAD "$NEW_COMMIT" "$PARENT"
